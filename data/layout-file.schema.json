{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deputat36.github.io/etagi/data/layout-file.schema.json",
  "title": "Файл макета генератора расклеек Этажи",
  "description": "Плоский JSON-формат для переноса одного макета между браузерами. Старые файлы без служебных полей продолжают поддерживаться.",
  "type": "object",
  "properties": {
    "$schema": {"type": "string"},
    "fileFormat": {"const": "etagi-raskleyka-layout"},
    "fileFormatVersion": {"type": "integer", "minimum": 1, "maximum": 1},
    "exportedAt": {"type": "string", "format": "date-time"},
    "version": {"type": "string"},
    "goal": {"enum": ["seller", "buyer", "object", "newbuild", "service", "rent", "brand", "private"]},
    "templateId": {"type": "string"},
    "layoutName": {"type": "string"},
    "layoutMode": {"enum": ["manual", "readable", "economy", "photo", "photo_left", "photo_card", "newbuild_visual", "agent_brand_photo", "showcase", "entrance", "private"]},
    "blockOrder": {
      "type": "array",
      "items": {"enum": ["headline", "price", "photo", "description", "meta", "benefits", "customBlock", "contact"]},
      "uniqueItems": true
    },
    "agentName": {"type": "string"},
    "agentPhone": {"type": "string"},
    "area": {"type": "string"},
    "propertyType": {"type": "string"},
    "price": {"type": "string"},
    "params": {"type": "string"},
    "headline": {"type": "string"},
    "description": {"type": "string"},
    "benefits": {"type": "string"},
    "customBlockTitle": {"type": "string"},
    "customBlockText": {"type": "string"},
    "contactCta": {"type": "string"},
    "tearOffLabel": {"type": "string"},
    "brandName": {"type": "string"},
    "brandSideText": {"type": "string"},
    "photoMode": {"enum": ["none", "one", "two", "plan"]},
    "photoOne": {"type": "string"},
    "photoTwo": {"type": "string"},
    "qrLink": {"type": "string"},
    "qrCaption": {"type": "string"},
    "printCount": {"enum": [1, 2, 3, 4, 6, 8]},
    "splitMode": {"enum": ["auto", "horizontal", "vertical", "grid"]},
    "colorMode": {"enum": ["brand", "economy", "bw", "private"]},
    "tearOffs": {"type": "boolean"},
    "showCutLines": {"type": "boolean"},
    "safePrintMargins": {"type": "boolean"},
    "printCheckMode": {"type": "boolean"},
    "pageMargin": {"type": "number", "minimum": 2, "maximum": 18},
    "pageGap": {"type": "number", "minimum": 1, "maximum": 12},
    "flyerPadding": {"type": "number", "minimum": 2, "maximum": 12},
    "radius": {"type": "number", "minimum": 0, "maximum": 30},
    "headlineScale": {"type": "number", "minimum": 0.75, "maximum": 1.45},
    "phoneScale": {"type": "number", "minimum": 0.8, "maximum": 1.8},
    "layoutDensity": {"enum": ["auto", "airy", "normal", "dense"]},
    "photoFit": {"enum": ["cover", "contain"]},
    "showBrand": {"type": "boolean"},
    "showHeadline": {"type": "boolean"},
    "showPrice": {"type": "boolean"},
    "showDescription": {"type": "boolean"},
    "showMeta": {"type": "boolean"},
    "showBenefits": {"type": "boolean"},
    "showCustomBlock": {"type": "boolean"},
    "showPhoto": {"type": "boolean"},
    "showQr": {"type": "boolean"},
    "showContact": {"type": "boolean"}
  },
  "anyOf": [
    {"required": ["fileFormat", "fileFormatVersion"]},
    {"required": ["goal"]},
    {"required": ["templateId"]},
    {"required": ["layoutName"]},
    {"required": ["headline"]},
    {"required": ["printCount"]}
  ],
  "additionalProperties": true
}
